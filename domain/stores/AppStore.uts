/**
 * 应用状态管理
 * 使用 EventBus + Storage 实现跨页面状态共享
 */

import {
  loadClassConfig,
  saveClassConfig,
  loadManagerName as loadManagerNameFromStorage,
  saveManagerName as saveManagerNameToStorage,
  getBinSeqMaxForFloor,
  setBinSeqMaxForFloor as setBinSeqMaxForFloorInStorage,
  saveDraftSession as saveDraftSessionToRepo,
  saveSubmittedSession as saveSubmittedSessionToRepo,
  loadSessionForEdit as loadSessionForEditFromRepo,
  deleteDraftSession as deleteDraftSessionFromRepo,
  deleteAllDraftSessions as deleteAllDraftSessionsFromRepo,
  getSessionsByDate as getSessionsByDateFromRepo,
  getAllDraftSessions as getAllDraftSessionsFromRepo,
  getSessionsByDateAndStage as getSessionsByDateAndStageFromRepo,
  saveLiangTangDefault as saveLiangTangDefaultToRepo,
  loadLiangTangDefault as loadLiangTangDefaultFromRepo,
  saveDuiQuDefault as saveDuiQuDefaultToRepo,
  loadDuiQuDefault as loadDuiQuDefaultFromRepo,
  loadPersons as loadPersonsFromRepo,
  savePersons as savePersonsToRepo,
  loadRounds as loadRoundsFromRepo,
  saveRounds as saveRoundsToRepo,
  loadRoundConfig as loadRoundConfigFromRepo,
  saveRoundConfig as saveRoundConfigToRepo,
  saveCoefSet as saveCoefSetToRepo,
  loadCoefSet as loadCoefSetFromRepo,
  getAllCoefSetIds as getAllCoefSetIdsFromRepo,
  saveActiveCoefSetId as saveActiveCoefSetIdToRepo,
  loadActiveCoefSetId as loadActiveCoefSetIdFromRepo,
  loadStageRoleDefaults as loadStageRoleDefaultsFromRepo,
  loadBins as loadBinsFromRepo,
  saveData as saveDataToRepo,
  loadData as loadDataFromRepo,
  removeData as removeDataFromRepo
} from '../../storage/storage-repository.uts'

import { getAnQuImportSnapshotKey } from '../../storage/storage-keys.uts'

import { resetAllStorage as resetAllStorageFromInit } from '../../storage/init.uts'

// ============================================
// 事件名称常量
// ============================================

export const EVENT_PERSON_ADDED = 'person:added'
export const EVENT_PERSON_UPDATED = 'person:updated'
export const EVENT_SESSION_SAVED = 'session:saved'
export const EVENT_SESSION_SUBMITTED = 'session:submitted'
export const EVENT_ROUND_CHANGED = 'round:changed'

// ============================================
// 班次配置
// ============================================

/**
 * 获取当前班次号
 * @returns 班次号（1或2）
 */
export function getCurrentClassNo(): number {
  const config = loadClassConfig()
  return config != null ? (config.classNo as number) : 1
}

/**
 * 设置当前班次号
 * @param classNo 班次号（1或2）
 */
export function setCurrentClassNo(classNo: number): void {
  saveClassConfig({ classNo: classNo } as UTSJSONObject)
}

// ============================================
// 管理员姓名
// ============================================

/**
 * 获取管理员姓名
 * @returns 管理员姓名
 */
export function getManagerName(): string {
  const name = loadManagerNameFromStorage()
  return name != null ? name : ''
}

/**
 * 设置管理员姓名
 * @param name 管理员姓名
 */
export function setManagerName(name: string): void {
  saveManagerNameToStorage(name)
}

// ============================================
// 发酵仓配置
// ============================================

/**
 * 获取指定楼层的最大仓号
 * @param floor 楼层号
 * @returns 最大仓号
 */
export function getBinSeqMax(floor: number): number {
  return getBinSeqMaxForFloor(floor)
}

/**
 * 设置指定楼层的最大仓号
 * @param floor 楼层号
 * @param maxSeq 最大仓号
 */
export function setBinSeqMax(floor: number, maxSeq: number): void {
  setBinSeqMaxForFloorInStorage(floor, maxSeq)
}

// ============================================
// 发酵仓数据
// ============================================

/**
 * 加载所有发酵仓数据
 * @returns 发酵仓数组
 */
export function loadBins(): UTSJSONObject[] {
  return loadBinsFromRepo()
}

// ============================================
// 会话数据
// ============================================

/**
 * 保存草稿会话
 * @param sessionDate 会话日期
 * @param stageCode 环节代码
 * @param classNo 班次号
 * @param sessionData 会话数据
 */
export function saveDraftSession(sessionDate: string, stageCode: string, classNo: number, sessionData: UTSJSONObject): void {
  saveDraftSessionToRepo(sessionDate, stageCode, classNo, sessionData)
  uni.$emit(EVENT_SESSION_SAVED, { sessionDate, stageCode, classNo } as UTSJSONObject)
}

/**
 * 保存已提交会话
 * @param sessionDate 会话日期
 * @param stageCode 环节代码
 * @param classNo 班次号
 * @param sessionData 会话数据
 */
export function saveSubmittedSession(sessionDate: string, stageCode: string, classNo: number, sessionData: UTSJSONObject): void {
  saveSubmittedSessionToRepo(sessionDate, stageCode, classNo, sessionData)
  uni.$emit(EVENT_SESSION_SUBMITTED, { sessionDate, stageCode, classNo } as UTSJSONObject)
}

/**
 * 加载会话用于编辑
 * @param sessionDate 会话日期
 * @param stageCode 环节代码
 * @param classNo 班次号
 * @returns 会话数据，不存在返回null
 */
export function loadSessionForEdit(sessionDate: string, stageCode: string, classNo: number): UTSJSONObject | null {
  return loadSessionForEditFromRepo(sessionDate, stageCode, classNo)
}

/**
 * 删除草稿会话
 * @param sessionDate 会话日期
 * @param stageCode 环节代码
 * @param classNo 班次号
 */
export function deleteDraftSession(sessionDate: string, stageCode: string, classNo: number): void {
  deleteDraftSessionFromRepo(sessionDate, stageCode, classNo)
}

/**
 * 删除所有草稿会话
 */
export function deleteAllDraftSessions(): void {
  deleteAllDraftSessionsFromRepo()
}

/**
 * 获取指定日期的所有会话
 * @param date 日期
 * @returns 会话数组
 */
export function getSessionsByDate(date: string): UTSJSONObject[] {
  return getSessionsByDateFromRepo(date)
}

/**
 * 获取所有草稿会话
 * @returns 草稿会话数组
 */
export function getAllDraftSessions(): UTSJSONObject[] {
  return getAllDraftSessionsFromRepo()
}

/**
 * 获取指定日期和环节的会话
 * @param date 日期
 * @param stageCode 环节代码
 * @returns 会话数组
 */
export function getSessionsByDateAndStage(date: string, stageCode: string): UTSJSONObject[] {
  return getSessionsByDateAndStageFromRepo(date, stageCode)
}

