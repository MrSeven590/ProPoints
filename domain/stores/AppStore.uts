// ============================================
// 堆曲默认人员
// ============================================

/**
 * 保存堆曲默认人员
 * @param classNo 班次号
 * @param defaults 默认人员数据
 */
export function saveDuiQuDefault(classNo: number, defaults: UTSJSONObject[]): void {
  saveDuiQuDefaultToRepo(classNo, defaults)
}

/**
 * 加载堆曲默认人员
 * @param classNo 班次号
 * @returns 默认人员数据，不存在返回null
 */
export function loadDuiQuDefault(classNo: number): UTSJSONObject[] | null {
  return loadDuiQuDefaultFromRepo(classNo)
