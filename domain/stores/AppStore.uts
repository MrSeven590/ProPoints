// ============================================
// 人员管理
// ============================================

/**
 * 加载所有人员
 * @returns 人员数组
 */
export function loadPersons(): UTSJSONObject[] {
  return loadPersonsFromRepo()
}

/**
 * 保存所有人员
 * @param persons 人员数组
 */
export function savePersons(persons: UTSJSONObject[]): void {
  savePersonsToRepo(persons)
}

/**
 * 添加人员
 * @param person 人员数据
 */
export function addPerson(person: UTSJSONObject): void {
  const persons = loadPersons()
  persons.push(person)
  savePersons(persons)
  uni.$emit(EVENT_PERSON_ADDED, person)
}

/**
 * 更新人员
 * @param personId 人员ID
 * @param updates 更新数据
 */
export function updatePerson(personId: number, updates: UTSJSONObject): void {
  const persons = loadPersons()
  for (let i = 0; i < persons.length; i++) {
    const p = persons[i]
    if (p['id'] == personId) {
      // 合并更新
      const keys = Object.keys(updates)
      for (let j = 0; j < keys.length; j++) {
        const key = keys[j]
        p[key] = updates[key]
      }
      break
    }
  }
  savePersons(persons)
  uni.$emit(EVENT_PERSON_UPDATED, { personId, updates } as UTSJSONObject)
}

/**
 * 根据ID查找人员
 * @param personId 人员ID
 * @returns 人员数据，不存在返回null
 */
export function findPersonById(personId: number): UTSJSONObject | null {
  const persons = loadPersons()
  for (let i = 0; i < persons.length; i++) {
    const p = persons[i]
    if (p['id'] == personId) {
      return p
    }
  }
  return null
}

