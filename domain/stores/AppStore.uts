// ============================================
// 安曲导入快照
// ============================================

/**
 * 保存安曲导入快照
 * @param classNo 班次号
 * @param roundId 轮次ID
 * @param snapshot 快照数据
 */
export function saveAnQuImportSnapshot(classNo: number, roundId: number, snapshot: UTSJSONObject): void {
  const key = getAnQuImportSnapshotKey(classNo, roundId)
  saveDataToRepo(key, snapshot)
}

/**
 * 加载安曲导入快照
 * @param classNo 班次号
 * @param roundId 轮次ID
 * @returns 快照数据，不存在返回null
 */
export function loadAnQuImportSnapshot(classNo: number, roundId: number): UTSJSONObject | null {
  const key = getAnQuImportSnapshotKey(classNo, roundId)
  return loadDataFromRepo(key)
}

/**
 * 删除安曲导入快照
 * @param classNo 班次号
 * @param roundId 轮次ID
 */
export function removeAnQuImportSnapshot(classNo: number, roundId: number): void {
  const key = getAnQuImportSnapshotKey(classNo, roundId)
  removeDataFromRepo(key)
}

// ============================================
// 系统管理
// ============================================

/**
 * 重置所有存储数据
 * 清除所有数据并重新初始化默认配置
 */
export function resetAllStorage(): void {
  resetAllStorageFromInit()
}
