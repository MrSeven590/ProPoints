// ============================================
// 系数配置
// ============================================

/**
 * 保存系数版本
 * @param setId 版本ID
 * @param coefSet 系数数据
 */
export function saveCoefSet(setId: number, coefSet: UTSJSONObject): void {
  saveCoefSetToRepo(setId, coefSet)
}

/**
 * 加载系数版本
 * @param setId 版本ID
 * @returns 系数数据，不存在返回null
 */
export function loadCoefSet(setId: number): UTSJSONObject | null {
  return loadCoefSetFromRepo(setId)
}

/**
 * 获取所有系数版本ID
 * @returns 版本ID数组
 */
export function getAllCoefSetIds(): number[] {
  return getAllCoefSetIdsFromRepo()
}

/**
 * 保存当前激活的系数版本ID
 * @param setId 版本ID
 */
export function saveActiveCoefSetId(setId: number): void {
  saveActiveCoefSetIdToRepo(setId)
}

/**
 * 加载当前激活的系数版本ID
 * @returns 版本ID，不存在返回null
 */
export function loadActiveCoefSetId(): number | null {
  return loadActiveCoefSetIdFromRepo()
}

/**
 * 加载当前激活的系数版本数据
 * @returns 系数数据，不存在返回null
 */
export function loadActiveCoefSet(): UTSJSONObject | null {
  const setId = loadActiveCoefSetId()
  if (setId == null) {
    return null
  }
  return loadCoefSet(setId)
}

