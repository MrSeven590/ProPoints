/**
 * 保存系数版本
 * @param setId 版本ID
 * @param coefSet 系数数据
 */
export function saveCoefSet(setId: number, coefSet: UTSJSONObject): void {
  saveCoefSetToRepo(setId, coefSet)
}

/**
 * 保存系数版本（仅在变更时创建新版本）
 * @param remark 备注（未使用，保留兼容性）
 * @param coefSet 系数数据
 * @returns 保存结果 { changed: boolean, setId: number }
 */
export function saveCoefSetIfChanged(remark: string, coefSet: UTSJSONObject): UTSJSONObject {
  const currentSetId = loadActiveCoefSetId() ?? 260000
  const currentCoefSet = loadCoefSet(currentSetId)

  // 比较系数是否变更
  let changed = false
  if (currentCoefSet == null) {
    changed = true
  } else {
    // 只比较系数字段，忽略元数据
    const normalizeCoefSet = (set: UTSJSONObject): UTSJSONObject => {
      return {
        stages: set['stages'],
        duiQu: set['duiQu'],
        liangTang: set['liangTang']
      } as UTSJSONObject
    }
    const currentNormalized = JSON.stringify(normalizeCoefSet(currentCoefSet))
    const newNormalized = JSON.stringify(normalizeCoefSet(coefSet))
    changed = currentNormalized != newNormalized
  }

  let resultSetId = currentSetId
  if (changed) {
    // 生成新版本ID（使用时间戳）
    resultSetId = getCurrentTimestamp()
    saveCoefSet(resultSetId, coefSet)
    saveActiveCoefSetId(resultSetId)
  }

  return {
    changed: changed,
    setId: resultSetId
  } as UTSJSONObject
}

