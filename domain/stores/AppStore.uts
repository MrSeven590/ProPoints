}

/**
 * 获取指定日期和环节的会话
 * @param date 日期
 * @param stageCode 环节代码
 * @returns 会话数组
 */
export function getSessionsByDateAndStage(date: string, stageCode: string): UTSJSONObject[] {
  return getSessionsByDateAndStageFromRepo(date, stageCode)
}

/**
 * 获取某轮次的所有已提交会话
 * @param roundId 轮次ID
 * @returns 会话数组
 */
function getSessionsByRoundId(roundId: number): UTSJSONObject[] {
  const allSessions: UTSJSONObject[] = []

  // 获取最近180天的所有会话
  const today = new Date()
  for (let i = 0; i < MAX_ROUND_QUERY_DAYS; i++) {
    const date = new Date(today.getTime() - i * 24 * 60 * 60 * 1000)
    const dateStr = date.toISOString().split('T')[0]
    const sessions = getSessionsByDate(dateStr)

    for (let j = 0; j < sessions.length; j++) {
      const session = sessions[j]
      const sessionRoundId = session['round_id'] as number | null
      const sessionStatus = session['status'] as string | null

      // 只收集已提交且匹配轮次的会话
      if (sessionStatus == 'submitted' && sessionRoundId == roundId) {
        allSessions.push(session)
      }
    }
  }

  return allSessions
}

