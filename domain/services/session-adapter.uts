 * @param options 构建选项
 * @returns SessionData
 */
export function entryPageStateToSessionData(
  state: SessionEntryPageState,
  options: SessionDataBuildOptions
): SessionData {
  // TODO: 后续 commit 实现
  return {} as SessionData
}
